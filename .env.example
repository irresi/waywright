# Waywright loop runtime env — copy to .env and fill in.
# Anthropic key intentionally omitted: claude.ts forces the `claude` subscription CLI path.

# Buildkite (Sensor)
BUILDKITE_API_TOKEN=bkua_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BUILDKITE_ORG=jaehwan-lee
BUILDKITE_PIPELINE=ouroboros-demo-target
BUILDKITE_MCP_URL=https://mcp.buildkite.com/direct

# Target repo the loop operates on
TARGET_REPO=irresi/waywright-demo-target
TARGET_DIR=../ouroboros-demo-target

# Merge gate (Pomerium-fronted in prod, direct in dev)
GATE_URL=http://localhost:8081/gate/merge
GATE_PORT=8081
GATE_MAX_ITER=3
